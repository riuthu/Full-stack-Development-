{{> header}}
<div id="contents">
<div class="box">
<div>
<div class="body">
<h1>Admin</h1>
<div id="admin-panel">
  <h2>Group Name</h2>
  <form action="/admin" method="post">
    <div>
      <label for="id">ID:</label>
      <input type="text" id="id" name="id">
    </div>
    <div>
      <label for="destination">Destination:</label>
      <input type="text" id="destination" name="destination">
    </div>
    <div>
      <label for="length">Length of Stay:</label>
      <input type="number" id="nights" name="nights" placeholder="Nights">
      <input type="number" id="days" name="days" placeholder="Days">
    </div>
    <div>
      <label for="startDate">Start Date:</label>
      <input type="date" id="startDate" name="startDate">
    </div>
    <div>
      <label for="resort">Resort:</label>
      <input type="text" id="resort" name="resort">
    </div>
    <div>
      <label for="perPerson">Per Person:</label>
      <input type="text" id="perPerson" name="perPerson">
    </div>
    <button type="submit">Save</button>
  </form>
</div>
</div>
</div>
</div>
</div>
{{> footer}}